# Auto-detect text files and normalize to LF
* text=auto eol=lf

# Explicit text file types
*.ts       text eol=lf
*.js       text eol=lf
*.json     text eol=lf
*.md       text eol=lf
*.sh       text eol=lf
*.yml      text eol=lf
*.yaml     text eol=lf
*.toml     text eol=lf

# Binary files — never modify
*.png      binary
*.jpg      binary
*.jpeg     binary
*.gif      binary
*.ico      binary
*.svg      binary
*.woff     binary
*.woff2    binary
*.eot      binary
*.ttf      binary

# Lock files
bun.lock   binary
