{
  "name": "qwen-forge",
  "version": "0.1.3-beta",
  "description": "Standalone Qwen account generator with clean architecture",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/alay-arch/qwen-forge.git"
  },
  "bugs": {
    "url": "https://github.com/alay-arch/qwen-forge/issues"
  },
  "homepage": "https://github.com/alay-arch/qwen-forge#readme",
  "keywords": ["qwen", "cli", "automation", "bun", "chromium"],
  "engines": {
    "bun": ">=1.3.0"
  },
  "type": "module",
  "main": "src/index.ts",
  "bin": {
    "qf": "./bin/qf"
  },
  "scripts": {
    "start": "bun run src/index.ts",
    "dev": "bun --watch run src/index.ts",
    "typecheck": "tsc --noEmit",
    "lint": "bun run typecheck",
    "test": "bun test"
  },
  "dependencies": {
    "cloakbrowser": "^0.4.5",
    "playwright-core": "^1.61.1"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "typescript": "^5.9.3"
  }
}