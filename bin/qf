#!/usr/bin/env bash
# Qwen Forge — CLi entry point
#
# Works in two modes:
#   1. Development:  bin/qf  (resolves relative to this script)
#   2. Installed:    ~/.qwen-forge/bin/qf  (uses QF_HOME or falls back)
#
set -euo pipefail

# Resolve the real script path through any symlink chain
SCRIPT="$0"
while [ -h "$SCRIPT" ]; do
  DIR="$(dirname "$SCRIPT")"
  LINK="$(readlink "$SCRIPT")"
  case "$LINK" in
    /*) SCRIPT="$LINK" ;;
    *)  SCRIPT="$DIR/$LINK" ;;
  esac
done
SCRIPT_DIR="$(cd "$(dirname "$SCRIPT")" && pwd)"
PROJECT_DIR="$(cd "$SCRIPT_DIR/.." && pwd)"

case "${1:-}" in
  --help|-h)
    cat <<'HELP'
 Qwen Forge v0.1.2-beta

 Usage:
   qf                     Launch interactive menu
   qf --debug             Run with TRACE logging
   qf --help              Show help
   qf --version           Show version

 Documentation:
   README.md     Russian
   README.en.md  English
HELP
    exit 0
    ;;
  --version|-v)
    printf 'v0.1.2-beta\n'
    exit 0
    ;;
esac

exec bun "$PROJECT_DIR/src/index.ts" -- "$@"
