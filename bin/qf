#!/usr/bin/env bash
# Qwen Forge — CLi entry point
#
# Works in two modes:
#   1. Development:  bin/qf  (resolves relative to this script)
#   2. Installed:    ~/.qwen-forge/bin/qf  (uses QF_HOME or falls back)
#
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
PROJECT_DIR="$(cd "$SCRIPT_DIR/.." && pwd)"

# If installed via install.sh, QF_HOME points to ~/.qwen-forge
if [ -n "${QF_HOME:-}" ]; then
  PROJECT_DIR="$QF_HOME"
fi

exec bun run "$PROJECT_DIR/src/index.ts" "$@"
